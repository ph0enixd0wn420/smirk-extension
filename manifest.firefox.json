{
  "manifest_version": 3,
  "name": "Smirk Wallet",
  "version": "0.1.3",
  "description": "Non-custodial multi-currency tip wallet for Telegram, Discord, and more",
  "browser_specific_settings": {
    "gecko": {
      "id": "wallet@smirk.cash",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "src/lib/grin/*.wasm",
        "src/lib/grin/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
